#!/usr/bin/env python3
"""Prepare a squash merge from a wip/ branch onto the target branch worktree."""

from __future__ import annotations

import argparse
from pathlib import Path
import subprocess
import sys
from typing import NoReturn


def fail(message: str) -> NoReturn:
    raise SystemExit(message)


def git(*args: str, cwd: Path | None = None) -> subprocess.CompletedProcess[str]:
    cmd = ["git"]
    if cwd is not None:
        cmd.extend(["-C", str(cwd)])
    return subprocess.run(
        [*cmd, *args],
        check=False,
        capture_output=True,
        text=True,
    )


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Run git merge --squash from a wip/ branch onto the target branch. "
            "If that branch is already checked out in another worktree, reuse that worktree "
            "instead of switching the current one. Leaves the squash staged for a later "
            "signed commit."
        )
    )
    parser.add_argument("target_branch", help="Branch to switch to before the squash merge.")
    parser.add_argument(
        "source_branch",
        nargs="?",
        help="wip/ branch to squash. Defaults to the current branch.",
    )
    return parser.parse_args(argv)


def current_branch() -> str:
    completed = git("symbolic-ref", "--quiet", "--short", "HEAD")
    if completed.returncode != 0:
        fail("Current HEAD is detached; pass an explicit source_branch")
    return completed.stdout.strip()


def require_clean_worktree(cwd: Path | None = None) -> None:
    completed = git("status", "--short", "--untracked-files=all", cwd=cwd)
    if completed.returncode != 0:
        fail(completed.stderr.strip() or completed.stdout.strip() or "git status failed")
    if completed.stdout.strip():
        fail("Refusing to switch branches with a dirty worktree")


def require_branch_exists(branch: str) -> None:
    completed = git("rev-parse", "--verify", "--quiet", branch)
    if completed.returncode != 0:
        fail(f"Source branch does not exist: {branch}")


def target_worktree(branch: str) -> Path | None:
    completed = git("worktree", "list", "--porcelain")
    if completed.returncode != 0:
        fail(completed.stderr.strip() or completed.stdout.strip() or "git worktree list failed")
    current_path: Path | None = None
    current_branch: str | None = None
    for line in [*completed.stdout.splitlines(), ""]:
        if not line:
            if current_path is not None and current_branch == f"refs/heads/{branch}":
                return current_path
            current_path = None
            current_branch = None
            continue
        key, _, value = line.partition(" ")
        if key == "worktree":
            current_path = Path(value)
        elif key == "branch":
            current_branch = value
    return None


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv or sys.argv[1:])
    source_branch = args.source_branch or current_branch()
    if not source_branch.startswith("wip/"):
        fail(f"Source branch must start with wip/: {source_branch}")
    if source_branch == args.target_branch:
        fail("Source and target branches must be different")

    require_clean_worktree()
    require_branch_exists(source_branch)
    landing_root = target_worktree(args.target_branch)
    if landing_root is None:
        landing_root = Path.cwd()
        switched = git("switch", args.target_branch, cwd=landing_root)
        if switched.returncode != 0:
            fail(switched.stderr.strip() or switched.stdout.strip() or "git switch failed")
    else:
        require_clean_worktree(landing_root)

    merged = git("merge", "--squash", source_branch, cwd=landing_root)
    if merged.returncode != 0:
        fail(merged.stderr.strip() or merged.stdout.strip() or "git merge --squash failed")

    print(f"squash-ready {source_branch} -> {args.target_branch}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
