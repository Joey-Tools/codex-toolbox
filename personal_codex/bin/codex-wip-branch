#!/usr/bin/env python3
"""Create and switch to a new wip/<topic> branch."""

from __future__ import annotations

import argparse
import subprocess
import sys
from typing import NoReturn


def fail(message: str) -> NoReturn:
    raise SystemExit(message)


def git(*args: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", *args],
        check=False,
        capture_output=True,
        text=True,
    )


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Create and switch to a new wip/<topic> branch in the current git worktree."
    )
    parser.add_argument("topic", help="Branch topic suffix; the helper prefixes it with wip/.")
    return parser.parse_args(argv)


def normalize_branch(topic: str) -> str:
    if not topic:
        fail("Topic must not be empty")
    if topic.startswith("wip/"):
        fail("Pass only the topic suffix; do not include the wip/ prefix")
    branch = f"wip/{topic}"
    checked = git("check-ref-format", "--branch", branch)
    if checked.returncode != 0:
        stderr = checked.stderr.strip() or checked.stdout.strip() or "invalid branch name"
        fail(f"Invalid wip branch name {branch!r}: {stderr}")
    return branch


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv or sys.argv[1:])
    branch = normalize_branch(args.topic)
    completed = git("switch", "-c", branch)
    if completed.returncode != 0:
        fail(completed.stderr.strip() or completed.stdout.strip() or "git switch failed")
    print(branch)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
